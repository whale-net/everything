# Python setup with rules_python for interpreter registration
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.13",
)
use_repo(python, "python_versions")

# Stripped Python builds from python-build-standalone for production containers
# These are optimized, production-ready builds (~20MB binary vs ~108MB debug)
http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# ── ESP32 Xtensa GCC cross-compiler (Espressif crosstool-NG, GCC 15.2) ──────
# GCC version: 15.2.0
# When upgrading, update _GCC_VERSION in tools/firmware/esp32/BUILD.bazel to match.
# The version string is used to locate compiler include directories at analysis time:
#   lib/gcc/xtensa-esp-elf/{version}/include
# (See tools/firmware/cc_toolchain_config.bzl for details.)
http_archive(
    name = "xtensa_esp_elf_linux64",
    build_file = "//tools/firmware/esp32:xtensa_toolchain.BUILD",
    sha256 = "3d50f5cd5f173acfd524e07c1cd69bc99585731a415ca2e5bce879997fe602b8",
    strip_prefix = "xtensa-esp-elf",
    urls = ["https://github.com/espressif/crosstool-NG/releases/download/esp-15.2.0_20251204/xtensa-esp-elf-15.2.0_20251204-x86_64-linux-gnu.tar.xz"],
)

# ── PubSubClient 2.8 (MQTT client for Arduino) ───────────────────────────────
http_archive(
    name = "pubsubclient",
    build_file = "//tools/firmware/esp32:pubsubclient.BUILD",
    sha256 = "837891318c255e1840917c4d1afe831d4e960375951cd2acfe15e0525b35fa8e",
    strip_prefix = "pubsubclient-2.8",
    urls = ["https://codeload.github.com/knolleary/pubsubclient/zip/refs/tags/v2.8"],
)

# ── Arduino ESP32 3.3.7 (ESP-IDF v5.5.2) ─────────────────────────────────────
# Release is split into two archives:
#   arduino_esp32      — framework sources: cores/, libraries/, variants/, tools/partitions/
#   arduino_esp32_libs — precompiled SDK:   include/, lib/*.a, ld/*.ld, bin/bootloader_*.elf
http_archive(
    name = "arduino_esp32",
    build_file = "//tools/firmware/esp32:arduino_core.BUILD",
    sha256 = "5267dc9a240daf4b8d26d3a1eb4c4f1dc8a40d43d527e6f6ce08cb6baaf6efac",
    strip_prefix = "esp32-core-3.3.7",
    urls = ["https://github.com/espressif/arduino-esp32/releases/download/3.3.7/esp32-core-3.3.7.zip"],
)

http_archive(
    name = "arduino_esp32_libs",
    build_file = "//tools/firmware/esp32:arduino_libs.BUILD",
    sha256 = "913cffb43e7fdd8f8ddcd045908fa49f98dfff28832706c850b66fe9ab324bd7",
    strip_prefix = "esp32-libs",
    urls = ["https://github.com/espressif/arduino-esp32/releases/download/3.3.7/esp32-libs-3.3.7.zip"],
)

# ── Toolchain registration ───────────────────────────────────────────────────
register_toolchains("//tools/firmware/esp32:xtensa_toolchain")

http_archive(
    name = "python_stripped_x86_64",
    build_file_content = """
exports_files(["python"])
""",
    url = "https://github.com/astral-sh/python-build-standalone/releases/download/20251014/cpython-3.13.9%2B20251014-x86_64-unknown-linux-gnu-install_only_stripped.tar.gz",
)

http_archive(
    name = "python_stripped_arm64",
    build_file_content = """
exports_files(["python"])
""",
    url = "https://github.com/astral-sh/python-build-standalone/releases/download/20251014/cpython-3.13.9%2B20251014-aarch64-unknown-linux-gnu-install_only_stripped.tar.gz",
)

# Pycross setup for cross-platform Python dependency management
# Create environments for different platforms
environments = use_extension("@rules_pycross//pycross/extensions:environments.bzl", "environments")
environments.create_for_python_toolchains(
    name = "everything_pycross_envs",
    # Pin to 3.13 explicitly: Pigweed's transitive deps register 3.10/3.11/3.12
    # (and something at 3.8), which rules_pycross 0.8.0 cannot handle as they
    # lack micro versions.  Scoping to our one version avoids the conflict.
    python_versions = ["3.13"],
    platforms = [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin",
    ],
)
use_repo(environments, "everything_pycross_envs")

# Import dependencies from uv.lock
lock_import = use_extension("@rules_pycross//pycross/extensions:lock_import.bzl", "lock_import")
lock_import.import_uv(
    lock_file = "//:uv.lock",
    project_file = "//:pyproject.toml",
    repo = "pypi",
    target_environments = ["@everything_pycross_envs//:environments"],
    # setuptools is the build backend for esptool (sdist-only package).
    # Without it, pycross wheel_builder can't build the esptool wheel.
    default_build_dependencies = ["setuptools"],
)

# Create the package repositories
lock_repos = use_extension("@rules_pycross//pycross/extensions:lock_repos.bzl", "lock_repos")
use_repo(lock_repos, "pypi")

# Go setup

go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(version = "1.25.0")

# Go dependencies - Automated via go_deps.from_file
go_deps = use_extension("@gazelle//:extensions.bzl", "go_deps")

# CRITICAL: This enables automatic transitive dependency resolution
# from go.mod. Bazel will automatically download all dependencies
# listed in go.mod and their transitive dependencies.
go_deps.from_file(go_mod = "//:go.mod")

# TEMPORARY PATCH: Fix Docker SDK v28.5.2 dependency issue
# Docker SDK imports github.com/containerd/errdefs/pkg/errhttp which doesn't exist
# in containerd/errdefs v1.0.0. This patch adds a stub package.
# TODO: Remove this patch once:
#   1. Docker SDK is updated to work with released containerd/errdefs versions, OR
#   2. containerd/errdefs re-adds the pkg/errhttp package
# See: tools/bazel/patches/PATCH_REMOVAL_PLAN.md for removal instructions
go_deps.module_override(
    patch_strip = 1,
    patches = [
        "//tools/bazel/patches:containerd-errdefs-pkg-errhttp.patch",
    ],
    path = "github.com/containerd/errdefs",
)

# OTel SDK internal/x visibility: sdk_metric needs access to sdk/internal/x
# but gazelle doesn't generate the visibility entry. Override with public
# visibility for the SDK module's internal packages.
go_deps.gazelle_override(
    directives = [
        "gazelle:default_visibility //visibility:public",
    ],
    path = "go.opentelemetry.io/otel/sdk",
)
go_deps.gazelle_override(
    directives = [
        "gazelle:default_visibility //visibility:public",
    ],
    path = "github.com/aws/aws-sdk-go-v2",
)
go_deps.gazelle_override(
    directives = [
        "gazelle:default_visibility //visibility:public",
    ],
    path = "github.com/aws/aws-sdk-go-v2/feature/s3/manager",
)
go_deps.gazelle_override(
    directives = [
        "gazelle:default_visibility //visibility:public",
    ],
    path = "github.com/riverqueue/river",
)
go_deps.gazelle_override(
    directives = [
        "gazelle:default_visibility //visibility:public",
    ],
    path = "github.com/riverqueue/river/riverdriver/riverpgxv5",
)
# NOTE: Do not run 'bazel mod tidy' - it will remove com_github_a_h_templ
