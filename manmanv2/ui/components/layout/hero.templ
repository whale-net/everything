package layout

// Hero renders a page hero section with gradient background
templ Hero(title, subtitle string) {
	<div class="bg-gradient-to-br from-indigo-600 to-purple-600 rounded-lg shadow-lg p-8 mb-8">
		<h1 class="text-4xl font-bold text-white mb-2">{ title }</h1>
		if subtitle != "" {
			<p class="text-indigo-100 text-lg">{ subtitle }</p>
		}
	</div>
}
