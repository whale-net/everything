{
  "description": "BH1750 light + SHT3x temp/humidity on root I2C bus (no mux)",
  "hardware": "BH1750 at 0x23, SHT3x at 0x44, both direct on root bus",
  "sensors": [
    {
      "chipType": "CHIP_TYPE_BH1750",
      "i2cAddress": 35,
      "name": "light",
      "enabled": true
    },
    {
      "chipType": "CHIP_TYPE_SHT3X",
      "i2cAddress": 68,
      "sensorType": "SENSOR_TYPE_TEMPERATURE",
      "name": "temperature",
      "enabled": true
    },
    {
      "chipType": "CHIP_TYPE_SHT3X",
      "i2cAddress": 68,
      "sensorType": "SENSOR_TYPE_HUMIDITY",
      "name": "humidity",
      "enabled": true
    }
  ]
}
