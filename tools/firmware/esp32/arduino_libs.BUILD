# ── Precompiled SDK static libraries ─────────────────────────────────────────
# cc_library so Bazel wraps them in --start-group/--end-group (see
# cc_toolchain_config.bzl libraries_to_link_feature).  Matches what
# Arduino's platform.txt does: link all SDK .a files in one group.

# ── SDK defines ───────────────────────────────────────────────────────────────
# Subset of flags/defines required for Arduino core compilation.
# Full list is in esp32-libs/flags/defines; this covers the essential ones.
# ESP_PLATFORM is critical: FreeRTOS.h gates ESP-IDF trace macros on it.
_SDK_DEFINES = [
    "ESP_PLATFORM",
    "IDF_VER=\\\"v5.5.2\\\"",
    "_GNU_SOURCE",
    "MBEDTLS_CONFIG_FILE=\\\"mbedtls/esp_config.h\\\"",
    "UNITY_INCLUDE_CONFIG_H",
    "_GLIBCXX_HAVE_POSIX_SEMAPHORE",
    "_GLIBCXX_USE_POSIX_SEMAPHORE",
    "_POSIX_READER_WRITER_LOCKS",
]

cc_library(
    name = "sdk_lib",
    srcs = glob(["lib/*.a"]) + [
        # Flash-mode-specific libspi_flash.a — provides spi_flash_mmap,
        # esp_mspi_pin_init, and other flash driver symbols.
        "dio_qspi/libspi_flash.a",
    ],
    hdrs = glob([
        "include/**/*.h",
        "dio_qspi/include/*.h",
    ]),
    defines = _SDK_DEFINES,
    includes = _SDK_INCLUDES,
    target_compatible_with = [
        "@platforms//os:none",
        "@@//tools/firmware:cpu_xtensa",
    ],
)
