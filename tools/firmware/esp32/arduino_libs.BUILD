"""Build file for the Arduino ESP32 libs archive (@arduino_esp32_libs).

Version: 3.3.7 (ESP-IDF v5.5.2).

Structure of esp32-libs/:
  include/   — ESP-IDF SDK headers (nested component tree; see _SDK_INCLUDES)
  lib/*.a    — precompiled ESP-IDF SDK static libraries
  ld/*.ld    — linker scripts (memory.ld, sections.ld, esp32.rom.*.ld, …)
  bin/       — bootloader ELF files (bootloader_dio_80m.elf, bootloader_qio_80m.elf, …)
  flags/     — text files with the exact build flags Arduino uses

_SDK_INCLUDES is derived verbatim from flags/includes in the archive:
  each '-iwithprefixbefore <path>' entry becomes '"include/<path>"'.
Bootloader conversion (ELF → BIN) is handled by genrules in
//tools/firmware/esp32:BUILD.bazel, which has access to esptool_wrapper.
"""

package(default_visibility = ["//visibility:public"])

# ── Linker scripts ────────────────────────────────────────────────────────────
# Exported so $(execpath @arduino_esp32_libs//:ld/memory.ld) works in
# additional_linker_inputs within esp32.bzl.

exports_files(glob(["ld/*.ld"]))

# ── Bootloader ELF files ──────────────────────────────────────────────────────
# Exposed as filegroups; //tools/firmware/esp32:BUILD.bazel converts them to
# flashable .bin files via esptool elf2image genrules.

filegroup(
    name = "bootloader_elf_dio_80m",
    srcs = ["bin/bootloader_dio_80m.elf"],
)

filegroup(
    name = "bootloader_elf_qio_80m",
    srcs = ["bin/bootloader_qio_80m.elf"],
)

# ── SDK include paths ─────────────────────────────────────────────────────────
# Derived verbatim from esp32-libs/flags/includes (Arduino ESP32 3.3.7).
# Each '-iwithprefixbefore <path>' maps to '"include/<path>"' here.
# Do not edit manually — regenerate from flags/includes if the libs version changes.

