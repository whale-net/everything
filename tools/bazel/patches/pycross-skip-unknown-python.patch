--- a/pycross/private/toolchain_helpers.bzl
+++ b/pycross/private/toolchain_helpers.bzl
@@ -14,9 +14,12 @@ def _get_micro_version(version):
     if version in MINOR_MAPPING:
         return MINOR_MAPPING[version]
     elif version in TOOL_VERSIONS:
         return version

-    fail("Unknown Python version: {}".format(version))
+    # Return None for EOL/unsupported versions (e.g. Python 3.8 registered by
